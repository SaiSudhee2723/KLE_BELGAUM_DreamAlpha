# ── COPY THIS TO .env AND FILL IN YOUR KEYS ──────────────────────────────────

# JWT (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=your_jwt_secret_here

# Gemini — PDF Extraction (https://aistudio.google.com)
GEMINI_API_KEY_1=your_gemini_key_1_here
GEMINI_API_KEY_2=your_gemini_key_2_here
GEMINI_API_KEY_3=your_gemini_key_3_here
GEMINI_API_KEY_4=your_gemini_key_4_here
GEMINI_API_KEY_5=your_gemini_key_5_here

# AWS Bedrock — LLaMA 3.1 70B (us-east-1)
LLAMA_AWS_ACCESS_KEY=your_aws_access_key_here
LLAMA_AWS_SECRET_KEY=your_aws_secret_key_here
LLAMA_AWS_REGION=us-east-1
LLAMA_MODEL_ID=us.meta.llama3-1-70b-instruct-v1:0

# AWS Bedrock — Mixtral 8x7B
MIXTRAL_AWS_ACCESS_KEY=your_aws_access_key_here
MIXTRAL_AWS_SECRET_KEY=your_aws_secret_key_here
MIXTRAL_AWS_REGION=us-east-1
MIXTRAL_MODEL_ID=mistral.mixtral-8x7b-instruct-v0:1

# Groq — LLM fallback (MUST be a valid Groq model name)
GROQ_API_KEY_1=your_groq_key_here
GROQ_API_KEY_2=your_groq_key_2_here
GROQ_LLM_MODEL=llama-3.1-70b-versatile

# Groq — Whisper ASR
OPENAI_API_KEY=your_groq_key_for_whisper_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
WHISPER_MODEL=whisper-large-v3

# SQLite DB path
DATABASE_URL=sqlite:///./patients.db

# Rate limits
RATE_LIMIT_DIAGNOSE_PER_HOUR=10
RATE_LIMIT_TTS_PER_HOUR=20
RATE_LIMIT_OCR_PER_HOUR=5

# Optional — Make.com webhooks
MAKE_WEBHOOK_REMINDER=https://hook.eu1.make.com/your_webhook_id
MAKE_WEBHOOK_HANDOFF=https://hook.eu1.make.com/your_webhook_id

# Optional — Supabase (for government sync)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key_here

# Optional — Backend public URL (for VAPI tool calls)
BACKEND_PUBLIC_URL=http://localhost:8000

# ── Firebase Auth (v4.0) ──────────────────────────────────────────────────────
# 1. Firebase Console → Project Settings → Service Accounts → Generate Key → download JSON
# 2. Either set the file path OR paste the full JSON as a string:
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# OR for cloud deployment (Render/Railway):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# 3. Firebase Console → Project Settings → General → Your apps → Web app
#    Copy the firebaseConfig object and paste it as JSON string:
FIREBASE_WEB_CONFIG={"apiKey":"AIza...","authDomain":"xxx.firebaseapp.com","projectId":"xxx","storageBucket":"xxx.appspot.com","messagingSenderId":"xxx","appId":"xxx"}

# ── How to get each key ───────────────────────────────────────────────────────
# GROQ:     groq.com → API Keys → Create → copy key starting with gsk_
# AWS:      AWS Console → IAM → Users → Create → Attach Bedrock policy → copy keys
# GEMINI:   aistudio.google.com → Get API Key → copy key starting with AIza
# JWT:      python -c "import secrets; print(secrets.token_hex(32))"
# VAPI:     vapi.ai → Dashboard → API Keys → create Public Key
# Firebase: See FIREBASE_SETUP_GUIDE.md for step-by-step setup

# VAPI Webhook Secret (optional — set in VAPI Dashboard → Webhooks)
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret_here

# ── VAPI Phone Numbers (for outbound patient calls) ───────────────────────────
# VAPI_PRIVATE_KEY: Dashboard → API Keys → Private Key (starts with vapi_prv_)
# Phone numbers: Dashboard → Phone Numbers → Buy a number
# VAPI_PHONE_NUMBER_ID_ASHA:    Phone number for ASHA outbound calls
# VAPI_PHONE_NUMBER_ID_PATIENT: Phone number for patient inbound calls
# VAPI_PHONE_NUMBER_ID_DOCTOR:  Phone number for doctor appointment booking
VAPI_PRIVATE_KEY=vapi_prv_your_private_key_here
VAPI_PHONE_NUMBER_ID_ASHA=your_asha_phone_number_id
VAPI_PHONE_NUMBER_ID_PATIENT=your_patient_phone_number_id
VAPI_PHONE_NUMBER_ID_DOCTOR=your_doctor_phone_number_id

# ── Make.com Fallback (use if VAPI outbound calls not working) ──────────────
# If VAPI_PRIVATE_KEY is not set, POST /vapi/call-patient falls back to this
# Create a Make.com scenario: Webhook → Twilio/WhatsApp → patient call/message
# make.com (free tier available) → New Scenario → Webhook → Copy URL here
MAKE_WEBHOOK_URL=https://hook.eu2.make.com/YOUR_WEBHOOK_ID_HERE
